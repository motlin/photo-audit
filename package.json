{
	"name": "photo-audit",
	"version": "0.1.0",
	"private": true,
	"description": "Identify (and later fix) date problems in a photo/video library",
	"type": "module",
	"scripts": {
		"build": "tsgo --noEmit && vp build",
		"oxlint": "vp lint . --fix",
		"oxlint:ci": "vp lint . --format github",
		"fmt": "vp fmt",
		"fmt:ci": "vp fmt --check",
		"fallow": "fallow fix --yes",
		"fallow:ci": "fallow dead-code",
		"typecheck": "tsgo --noEmit",
		"test": "node node_modules/vitest/dist/cli.js",
		"test:ui": "node node_modules/vitest/dist/cli.js --ui",
		"test:run": "node node_modules/vitest/dist/cli.js run",
		"audit": "tsx src/cli.ts",
		"prepare": "vp config"
	},
	"dependencies": {
		"better-sqlite3": "^12.10.0",
		"exiftool-vendored": "^35.20.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.9.1",
		"@typescript/native-preview": "^7.0.0-dev.20260525.1",
		"fallow": "^2.78.0",
		"markdownlint-cli2": "^0.22.1",
		"playwright": "^1.60.0",
		"tsx": "^4.22.3",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"packageManager": "pnpm@11.1.1"
}
